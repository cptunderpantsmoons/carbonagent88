# Carbon Agent Runtime Configuration
# Copy this file to .env and fill in your values.
# The application will load these at startup.

# === AI Provider API Keys ===
# At least one provider is required for the agent to function.
# Keys are stored encrypted in the local SQLite database after first startup.
# These environment variables are used to seed default providers on first run.

# OpenAI (ChatGPT, GPT-4, etc.)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Custom OpenAI-compatible endpoint (e.g. local LLM, Azure)
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_MODEL=

# === Application Configuration ===
# Override default paths and behavior.
# CARBON_DATA_DIR=           # Override default app data directory
# CARBON_LOG_LEVEL=info      # Logging level: debug | info | warn | error
# CARBON_LOG_PRETTY=true     # Pretty-print logs in development
# CARBON_TELEMETRY=false     # Enable anonymous usage analytics

# === Browser Orchestration ===
# CLOAK_HEADLESS=false       # Run browser in visible mode (debug)
# CLOAK_SLOW_MO=50           # Slow motion ms for debugging automation

# === Security ===
# These control secure storage behavior.
# safeStorage is used by default; these are fallback / override options.
# CARBON_ENCRYPTION_KEY=     # Override the machine-derived encryption key

# === Desktop Daemon ===
# DAEMON_MODE=true             # Run as background tray daemon (hide on close)
# TRAY_ENABLED=true            # Show system tray icon
# HOTKEY_CAPTURE=CommandOrControl+Shift+C  # Global hotkey to capture active window
# HOTKEY_TOGGLE=CommandOrControl+Shift+X # Global hotkey to show/hide app
# SCREEN_CAPTURE_INTERVAL_MS=30000       # Polling interval for automatic capture
# SCREEN_CAPTURE_PRIVACY_MODE=false        # Return placeholder images, skip screenshots
