{
  "name": "carbon-agent-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "dev": "electron .",
    "test": "vitest run",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@carbon-agent/cloak-bridge": "workspace:*",
    "@carbon-agent/core-runtime": "workspace:*",
    "@carbon-agent/ingestion": "workspace:*",
    "@carbon-agent/local-store": "workspace:*",
    "@carbon-agent/shared-schemas": "workspace:*",
    "docx": "^9.7.1",
    "dotenv": "^16.4.7",
    "pdf-lib": "^1.17.1",
    "electron-updater": "^6.6.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.corporatecarbon.carbon-agent",
    "productName": "Carbon Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "your-org",
      "repo": "carbon-agent"
    }
  }
}
