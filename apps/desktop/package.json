{
  "name": "carbon-agent-desktop",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.txt",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:assets": "bash build.sh",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "dev": "electron .",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:install": "playwright install",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:win:portable": "electron-builder --win portable --x64",
    "dist:linux": "electron-builder --linux --x64",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "@carbon-agent/cloak-bridge": "workspace:*",
    "@carbon-agent/connectors": "workspace:*",
    "@carbon-agent/core-runtime": "workspace:*",
    "@carbon-agent/ingestion": "workspace:*",
    "@carbon-agent/local-store": "workspace:*",
    "@carbon-agent/shared-schemas": "workspace:*",
    "chokidar": "^5.0.0",
    "docx": "^9.7.1",
    "dotenv": "^16.4.7",
    "electron-updater": "^6.6.4",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.9.1",
    "bcryptjs": "^3.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.corporatecarbon.carbon-agent",
    "productName": "Carbon Agent",
    "copyright": "Copyright © 2026 Corporate Carbon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-win-${arch}.${ext}",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Carbon Agent",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "license": "LICENSE.txt"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-portable.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "publish": null
  }
}
