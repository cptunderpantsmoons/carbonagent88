<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron/V8 JavaScript engine JIT compilation -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Required for loading native modules (sql.js, Playwright, etc.) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Required for accessibility features (screen reader support, input monitoring) -->
  <key>com.apple.security.accessibility</key>
  <true/>
  <!-- Required for screen capture (document context, active window detection) -->
  <key>com.apple.security.screen-capture</key>
  <true/>
</dict>
</plist>